{
    "manifest_version": 3,
    "name": "Video URL Sender",
    "description": "Detecte les URLs .m3u8 et .mp4 et les envoie au serveur local.",
    "version": "1.0.0",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "webRequest",
        "downloads",
        "scripting",
        "alarms",
        "cookies"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Video URL Sender",
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script-main.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "page-hook.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}
